# ── Server connection ──────────────────────────────────────────────────────────
# URL of the ai_captain orchestration server
SERVER_BASE_URL=http://localhost:3000

# Password for the single user account on the server (used only during actor bootstrapping)
SERVER_USER_PASSWORD=changeme

# ── Team configuration ─────────────────────────────────────────────────────────
# Absolute path to the working directory where the team checks out/builds projects
WORK_DIR=/home/ai/workspace

# Path to the persisted actor tokens file (default: .tokens.json in cwd)
# TOKENS_FILE=.tokens.json

# How often to poll the server in milliseconds (default: 60000 = 1 minute)
# POLL_INTERVAL_MS=60000

# Path to the model endpoints configuration file (default: ./environments.json)
# ENVIRONMENTS_FILE=./environments.json

# ── Git host (exfiltration) ────────────────────────────────────────────────────
# When set, ai-crew automatically creates a repo on this server for each project
# and pushes to it after every approved squash merge and release tag.
# Both vars must be set together, or both omitted (opt-in feature).
# GIT_HOST_URL=http://192.168.0.56:3456
# GIT_HOST_PASSWORD=changeme

# ── Model API keys ─────────────────────────────────────────────────────────────
# These are referenced by name in environments.json via the api_key_env field.
# Add one entry here per endpoint you configure.

# Example for Anthropic API (OpenAI-compatible endpoint)
# ANTHROPIC_API_KEY=sk-ant-...

# Example for a local Ollama instance (usually no key needed)
# STRIX_API_KEY=ollama

# Example for OpenAI directly
# OPENAI_API_KEY=sk-...
